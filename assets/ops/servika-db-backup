#!/usr/bin/env bash
# Back up the Servika panel database for the daily timer and pre-update recovery.
# Authentication uses the root Unix socket. The completed dump path is written to stdout.
set -euo pipefail

ENV_FILE=/etc/servika/env

load_servika_env() {
  [ -f "$ENV_FILE" ] || return 0
  [ "$(stat -c %u "$ENV_FILE" 2>/dev/null)" = 0 ] || { echo "insecure environment file owner" >&2; exit 1; }
  mode=$(stat -c %a "$ENV_FILE" 2>/dev/null) || { echo "could not read environment file mode" >&2; exit 1; }
  [ $((8#$mode & 077)) -eq 0 ] || { echo "insecure environment file mode" >&2; exit 1; }

  while IFS= read -r line || [ -n "$line" ]; do
    [[ "$line" =~ ^[[:space:]]*(SERVIKA_[A-Za-z0-9_]*)=(.*)$ ]] || continue
    key=${BASH_REMATCH[1]}
    value=${BASH_REMATCH[2]%$'\r'}
    if [[ "$value" == \"*\" && "$value" == *\" ]]; then value=${value:1:${#value}-2}; fi
    if [[ "$value" == \'*\' && "$value" == *\' ]]; then value=${value:1:${#value}-2}; fi
    if [ -z "${!key+x}" ]; then
      printf -v "$key" '%s' "$value"
      export "${key?}"
    fi
  done < "$ENV_FILE"
}

load_servika_env
BACKUP_DIR="${SERVIKA_DBDIR:-/var/backups/servika/db}"
case "$BACKUP_DIR" in
  /*) ;;
  *) echo "SERVIKA_DBDIR must be an absolute path: $BACKUP_DIR" >&2; exit 1 ;;
esac
RETENTION_DAYS=14
mkdir -p "$BACKUP_DIR"
chmod 700 "$BACKUP_DIR"

timestamp=$(date +%F-%H%M%S)
temporary="$BACKUP_DIR/.panel-$timestamp.sql.gz.tmp"
final="$BACKUP_DIR/panel-$timestamp.sql.gz"
trap 'rm -f "$temporary"' EXIT

# Create a consistent InnoDB snapshot including stored database objects.
mysqldump --single-transaction --routines --triggers --events \
  --databases panel | gzip -c > "$temporary"

# Publish only complete, valid dumps.
gzip -t "$temporary"
[ "$(stat -c%s "$temporary")" -gt 1000 ] || {
  rm -f "$temporary"
  echo "database dump is suspiciously small" >&2
  exit 1
}

mv -f "$temporary" "$final"
chmod 600 "$final"

# Retain only this tool's panel database dumps and remove abandoned temporary files.
find "$BACKUP_DIR" -maxdepth 1 -type f -name 'panel-*.sql.gz' \
  -mtime +"$RETENTION_DAYS" -delete
find "$BACKUP_DIR" -maxdepth 1 -type f -name '.panel-*.sql.gz.tmp' \
  -mtime +1 -delete

echo "$final"

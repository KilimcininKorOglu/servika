#!/bin/bash
# servika-jail provides a per-user chroot jail similar to a jailed shell.
# It combines a shared hard-linked template with a bind-mounted real home directory.
# FTP, nginx, and PHP keep using /home/<user>; the jail restricts only SSH sessions.
set -o pipefail

ENV_FILE=/etc/servika/env

load_servika_env() {
  [ -f "$ENV_FILE" ] || return 0
  [ "$(stat -c %u "$ENV_FILE" 2>/dev/null)" = 0 ] || { echo "insecure environment file owner" >&2; exit 1; }
  mode=$(stat -c %a "$ENV_FILE" 2>/dev/null) || { echo "could not read environment file mode" >&2; exit 1; }
  [ $((8#$mode & 077)) -eq 0 ] || { echo "insecure environment file mode" >&2; exit 1; }

  while IFS= read -r line || [ -n "$line" ]; do
    [[ "$line" =~ ^[[:space:]]*(SERVIKA_[A-Za-z0-9_]*)=(.*)$ ]] || continue
    key=${BASH_REMATCH[1]}
    value=${BASH_REMATCH[2]%$'\r'}
    if [[ "$value" == \"*\" && "$value" == *\" ]]; then value=${value:1:${#value}-2}; fi
    if [[ "$value" == \'*\' && "$value" == *\' ]]; then value=${value:1:${#value}-2}; fi
    if [ -z "${!key+x}" ]; then
      printf -v "$key" '%s' "$value"
      export "${key?}"
    fi
  done < "$ENV_FILE"
}

load_servika_env
JAILROOT=/home/jails
TEMPLATE=/opt/servika/jail-template

BINS="/usr/bin/bash /usr/bin/ls /usr/bin/cat /usr/bin/cp /usr/bin/mv /usr/bin/rm \
/usr/bin/mkdir /usr/bin/rmdir /usr/bin/pwd /usr/bin/chmod /usr/bin/touch /usr/bin/ln \
/usr/bin/find /usr/bin/grep /usr/bin/head /usr/bin/tail /usr/bin/less /usr/bin/nano \
/usr/bin/tar /usr/bin/gzip /usr/bin/gunzip /usr/bin/unzip /usr/bin/curl /usr/bin/wget \
/usr/bin/git /usr/bin/id /usr/bin/whoami /usr/bin/env /usr/bin/du /usr/bin/clear \
/usr/bin/date /usr/bin/sed /usr/bin/awk /usr/bin/sort /usr/bin/wc /usr/bin/stat /usr/bin/file \
/usr/bin/tr /usr/bin/cut /usr/bin/tee /usr/bin/sleep /usr/bin/seq /usr/bin/xargs /usr/bin/uniq \
/usr/bin/comm /usr/bin/mktemp /usr/bin/readlink /usr/bin/dirname /usr/bin/basename /usr/bin/which \
/usr/bin/diff /usr/bin/vi /usr/bin/chown /usr/bin/chgrp /usr/bin/df /usr/bin/free /usr/bin/md5sum \
/usr/bin/sha256sum /usr/bin/realpath /usr/bin/dos2unix /usr/bin/rsync"

copy_with_libs() {
  local bin="$1" jail_dir="$2" real
  real=$(readlink -f "$bin" 2>/dev/null || echo "$bin")
  [ -e "$real" ] || return 0
  mkdir -p "$jail_dir$(dirname "$real")"
  cp -f "$real" "$jail_dir$real"
  # Preserve the original path when it is a symlink.
  if [ "$real" != "$bin" ]; then mkdir -p "$jail_dir$(dirname "$bin")"; ln -sf "$real" "$jail_dir$bin" 2>/dev/null || cp -f "$real" "$jail_dir$bin"; fi
  ldd "$real" 2>/dev/null | grep -oE '/[^ ]+\.so[^ ]*' | while read -r lib; do
    [ -e "$lib" ] || continue
    mkdir -p "$jail_dir$(dirname "$lib")"
    cp -f "$lib" "$jail_dir$lib" 2>/dev/null || true
  done
}

build_template() {
  rm -rf "$TEMPLATE"; mkdir -p "$TEMPLATE"/{bin,usr/bin,lib64,lib,etc,dev,tmp,home,usr/share/terminfo}
  chmod 1777 "$TEMPLATE/tmp"
  for b in $BINS; do copy_with_libs "$b" "$TEMPLATE"; done
  # Dynamic linker and NSS support for getpwnam and hostname resolution.
  for f in /lib64/ld-linux-x86-64.so.2 /lib64/libnss_files.so.2 /lib64/libnss_dns.so.2 \
           /lib64/libresolv.so.2 /lib64/libnsl.so.1 /lib64/libnss_compat.so.2; do
    [ -e "$f" ] && { mkdir -p "$TEMPLATE$(dirname "$f")"; cp -f "$f" "$TEMPLATE$f"; }
  done
  # Keep /bin compatible with /usr/bin.
  ( cd "$TEMPLATE" || exit; [ -e bin/bash ] || cp usr/bin/bash bin/bash 2>/dev/null; ln -sf bash bin/sh 2>/dev/null )
  cp -f "$TEMPLATE/usr/bin/"* "$TEMPLATE/bin/" 2>/dev/null || true
  # terminfo entries required by nano, less, and clear
  for d in x l v s; do cp -a "/usr/share/terminfo/$d" "$TEMPLATE/usr/share/terminfo/" 2>/dev/null || true; done
  # etc
  printf 'passwd: files\ngroup: files\nhosts: files dns\n' > "$TEMPLATE/etc/nsswitch.conf"
  cp -f /etc/resolv.conf "$TEMPLATE/etc/" 2>/dev/null || true
  echo "root:x:0:0:root:/root:/bin/bash" > "$TEMPLATE/etc/passwd"
  echo "root:x:0:" > "$TEMPLATE/etc/group"
  echo "127.0.0.1 localhost" > "$TEMPLATE/etc/hosts"
  printf 'export PS1="[\\u@%s \\W]\\$ "\nexport PATH=/bin:/usr/bin\nexport TERM=${TERM:-xterm}\numask 022\n' "servika-jail" > "$TEMPLATE/etc/profile"
  chown -R root:root "$TEMPLATE"
  echo "template OK: $TEMPLATE ($(du -sh "$TEMPLATE" 2>/dev/null | cut -f1))"
}

setup() {
  local system_user="$1"
  [[ "$system_user" == c_* ]] || { echo "ERROR: user does not have the c_ prefix"; exit 1; }
  local home="/home/$system_user" jail_dir="$JAILROOT/$system_user"
  [ -d "$home" ] || { echo "ERROR: home directory not found: $home"; exit 1; }
  [ -d "$TEMPLATE" ] || build_template
  mkdir -p "$JAILROOT"; chown root:root "$JAILROOT"; chmod 755 "$JAILROOT"
  # Unmount the previous bind mount.
  mountpoint -q "$jail_dir/home/$system_user" && { umount "$jail_dir/home/$system_user" 2>/dev/null || umount -l "$jail_dir/home/$system_user"; }
  rm -rf "$jail_dir"; mkdir -p "$jail_dir"
  # Copy the template with hard links to share disk blocks on the same filesystem.
  cp -al "$TEMPLATE/." "$jail_dir/" 2>/dev/null || cp -a "$TEMPLATE/." "$jail_dir/"
  chown root:root "$jail_dir"; chmod 755 "$jail_dir"
  # Device nodes
  mkdir -p "$jail_dir/dev"
  [ -e "$jail_dir/dev/null" ]    || mknod -m 666 "$jail_dir/dev/null" c 1 3
  [ -e "$jail_dir/dev/zero" ]    || mknod -m 666 "$jail_dir/dev/zero" c 1 5
  [ -e "$jail_dir/dev/random" ]  || mknod -m 666 "$jail_dir/dev/random" c 1 8
  [ -e "$jail_dir/dev/urandom" ] || mknod -m 666 "$jail_dir/dev/urandom" c 1 9
  [ -e "$jail_dir/dev/tty" ]     || mknod -m 666 "$jail_dir/dev/tty" c 5 0
  # Jail passwd and group entries for root and the tenant user
  echo "root:x:0:0:root:/root:/bin/bash" > "$jail_dir/etc/passwd"
  getent passwd "$system_user" | awk -F: -v OFS=: '{$7="/bin/bash"; print}' >> "$jail_dir/etc/passwd"
  echo "root:x:0:" > "$jail_dir/etc/group"
  getent group "$system_user" >> "$jail_dir/etc/group"
  # Bind-mount the real home directory inside the jail.
  mkdir -p "$jail_dir/home/$system_user"
  mount --bind "$home" "$jail_dir/home/$system_user"
  # Persist the bind mount in fstab; nofail prevents a missing target from blocking boot.
  local line="$home $jail_dir/home/$system_user none bind,nofail,x-systemd.requires-mounts-for=$home 0 0"
  grep -qF "$jail_dir/home/$system_user none bind" /etc/fstab || echo "$line" >> /etc/fstab
  restorecon -R "$jail_dir" 2>/dev/null || true
  echo "setup OK: $jail_dir"
}

teardown() {
  local system_user="$1"
  [[ "$system_user" == c_* ]] || { echo "ERROR: user does not have the c_ prefix; teardown canceled"; exit 1; }
  local jail_dir="$JAILROOT/$system_user"
  local bind_path="$jail_dir/home/$system_user"
  [ -d "$jail_dir" ] || { echo "teardown: jail not found ($system_user)"; return 0; }
  # Unmount the bind without fuser -km, which can target the parent filesystem and kill
  # system processes. A lazy unmount is sufficient when a session is still active.
  if mountpoint -q "$bind_path"; then umount "$bind_path" 2>/dev/null || umount -l "$bind_path" 2>/dev/null || true; fi
  sed -i "\|$bind_path none bind|d" /etc/fstab
  # Do not delete a jail that remains mounted, which could traverse into the real home.
  if mountpoint -q "$bind_path"; then echo "WARNING: bind mount could not be detached; jail directory preserved: $jail_dir"; return 0; fi
  rm -rf "$jail_dir"
  echo "teardown OK: $system_user"
}

case "${1:-}" in
  template) build_template ;;
  setup)    setup "${2:?c_user required}" ;;
  teardown) teardown "${2:?c_user required}" ;;
  *) echo "usage: $0 {template|setup <c_user>|teardown <c_user>}"; exit 1 ;;
esac

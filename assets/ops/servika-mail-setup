#!/usr/bin/env bash
# servika-mail-setup installs or repairs Postfix, Dovecot, and OpenDKIM for virtual mailboxes.
# It reads mail_domains, mailboxes, and mail_aliases through live MySQL maps.
set -uo pipefail

ENV_FILE=/etc/servika/env

load_servika_env() {
  [ -f "$ENV_FILE" ] || return 0
  [ "$(stat -c %u "$ENV_FILE" 2>/dev/null)" = 0 ] || { echo "insecure environment file owner" >&2; exit 1; }
  mode=$(stat -c %a "$ENV_FILE" 2>/dev/null) || { echo "could not read environment file mode" >&2; exit 1; }
  [ $((8#$mode & 077)) -eq 0 ] || { echo "insecure environment file mode" >&2; exit 1; }

  while IFS= read -r line || [ -n "$line" ]; do
    [[ "$line" =~ ^[[:space:]]*(SERVIKA_[A-Za-z0-9_]*)=(.*)$ ]] || continue
    key=${BASH_REMATCH[1]}
    value=${BASH_REMATCH[2]%$'\r'}
    if [[ "$value" == \"*\" && "$value" == *\" ]]; then value=${value:1:${#value}-2}; fi
    if [[ "$value" == \'*\' && "$value" == *\' ]]; then value=${value:1:${#value}-2}; fi
    if [ -z "${!key+x}" ]; then
      printf -v "$key" '%s' "$value"
      export "${key?}"
    fi
  done < "$ENV_FILE"
}

ensure_env_file() {
  mkdir -p "$(dirname "$ENV_FILE")"
  touch "$ENV_FILE"
  chown root:root "$ENV_FILE" 2>/dev/null || true
  chmod 600 "$ENV_FILE"
}

set_env_value() {
  key=$1
  value=$2
  ensure_env_file
  tmp=$(mktemp)
  if [ -f "$ENV_FILE" ]; then
    grep -v -E "^${key}=" "$ENV_FILE" > "$tmp" 2>/dev/null || true
  fi
  printf '%s=%s\n' "$key" "$value" >> "$tmp"
  install -m 600 -o root -g root "$tmp" "$ENV_FILE"
  rm -f "$tmp"
}

log(){ printf '  %s\n' "$*"; }
fail(){ log "✗ $*"; exit 1; }

[ "$(id -u)" = 0 ] || fail "root is required"
load_servika_env

TMPL="/opt/servika/src/mail-templates"
if [ ! -d "$TMPL" ]; then
  HERE="$(cd "$(dirname "$0")" && pwd)"
  for cand in "$HERE/../assets/mail" "$HERE/assets/mail"; do
    [ -d "$cand" ] && TMPL="$cand" && break
  done
fi
[ -d "$TMPL" ] || fail "mail template directory was not found ($TMPL)"

for dir in postfix dovecot opendkim; do
  [ -d "$TMPL/$dir" ] || fail "mail template directory is incomplete: $TMPL/$dir"
done

echo "════ Postfix + Dovecot + OpenDKIM packages ════"
dnf install -y postfix postfix-mysql dovecot dovecot-mysql opendkim >/tmp/servika-mail-setup.log 2>&1 \
  && log "postfix + postfix-mysql + dovecot + dovecot-mysql + opendkim installed" || fail "mail packages could not be installed"

echo "════ mailro database password ════"
DBPASS=${SERVIKA_MAIL_DB_PASS:-}
if [ -n "$DBPASS" ] && ! [[ "$DBPASS" =~ ^[A-Za-z0-9._%+=:@-]{16,128}$ ]]; then
  fail "SERVIKA_MAIL_DB_PASS contains unsupported characters or has an invalid length"
fi
if [ -z "$DBPASS" ]; then
  DBPASS=$(openssl rand -hex 24)
  set_env_value SERVIKA_MAIL_DB_PASS "$DBPASS"
  export SERVIKA_MAIL_DB_PASS="$DBPASS"
  log "mailro password generated and added to the environment file"
fi

echo "════ mailro database user ════"
mysql -u root <<SQL 2>/dev/null || fail "mailro user or grants could not be created"
CREATE USER IF NOT EXISTS 'mailro'@'127.0.0.1' IDENTIFIED BY '${DBPASS}';
ALTER USER 'mailro'@'127.0.0.1' IDENTIFIED BY '${DBPASS}';
GRANT SELECT ON panel.mail_domains TO 'mailro'@'127.0.0.1';
GRANT SELECT ON panel.mailboxes TO 'mailro'@'127.0.0.1';
GRANT SELECT ON panel.mail_aliases TO 'mailro'@'127.0.0.1';
FLUSH PRIVILEGES;
SQL
log "mailro user has SELECT access to mail tables"

echo "════ Postfix virtual mailbox maps ════"
for f in mysql-virtual-domains.cf mysql-virtual-mailboxes.cf mysql-virtual-uid.cf mysql-virtual-gid.cf mysql-virtual-aliases.cf; do
  sed "s/__SERVIKA_MAIL_DB_PASS__/${DBPASS}/" "$TMPL/postfix/${f}.tmpl" > "/etc/postfix/${f}"
  chown root:postfix "/etc/postfix/${f}"
  chmod 640 "/etc/postfix/${f}"
done
log "5 mysql-virtual-*.cf files written"

echo "════ Postfix main.cf and master.cf ════"
if ! grep -q 'servika-mail' /etc/postfix/main.cf; then
  cat "$TMPL/postfix/main.cf.append" >> /etc/postfix/main.cf
  log "servika-mail block added to main.cf"
fi
if ! grep -qE '^submission[[:space:]]+inet' /etc/postfix/master.cf; then
  cat "$TMPL/postfix/master.cf.append" >> /etc/postfix/master.cf
  log "submission service added to master.cf"
fi

echo "════ Dovecot SQL auth and drop-in config ════"
sed "s/__SERVIKA_MAIL_DB_PASS__/${DBPASS}/" "$TMPL/dovecot/dovecot-sql.conf.ext.tmpl" > /etc/dovecot/dovecot-sql.conf.ext
chown root:dovecot /etc/dovecot/dovecot-sql.conf.ext
chmod 640 /etc/dovecot/dovecot-sql.conf.ext
cp "$TMPL/dovecot/10-servika-mail.conf.tmpl" /etc/dovecot/conf.d/10-servika-mail.conf
log "dovecot-sql.conf.ext and 10-servika-mail.conf installed"

echo "════ OpenDKIM ════"
mkdir -p /etc/opendkim/keys
touch /etc/opendkim/KeyTable /etc/opendkim/SigningTable
if [ ! -f /etc/opendkim/TrustedHosts ]; then
  printf '127.0.0.1\nlocalhost\n' > /etc/opendkim/TrustedHosts
fi
chown -R opendkim:opendkim /etc/opendkim
cp "$TMPL/opendkim/opendkim.conf.tmpl" /etc/opendkim/opendkim.conf
chown root:opendkim /etc/opendkim/opendkim.conf
log "opendkim.conf and table files installed"

echo "════ Maildir roots for active domains ════"
mysql -u root -N -e "SELECT system_user FROM panel.mail_domains WHERE status='active'" 2>/dev/null | while read -r system_user; do
  [ -n "$system_user" ] || continue
  getent passwd "$system_user" >/dev/null || continue
  mkdir -p "/home/${system_user}/mail"
  chown "${system_user}:${system_user}" "/home/${system_user}/mail" 2>/dev/null
  chmod 750 "/home/${system_user}/mail" 2>/dev/null
done

echo "════ SELinux ════"
setsebool -P httpd_can_network_connect_db 1 2>/dev/null && log "httpd_can_network_connect_db=1"
if command -v getenforce >/dev/null 2>&1 && [ "$(getenforce)" != "Disabled" ]; then
  log "SELinux is enforcing; run servika-repair --only mail if mail service AVC denials appear"
fi

echo "════ postfix + dovecot + opendkim enable and restart ════"
systemctl enable postfix dovecot opendkim >/dev/null 2>&1
if ! postfix check >/tmp/servika-mail-postfix-check.log 2>&1; then
  log "✗ postfix check failed; see /tmp/servika-mail-postfix-check.log"
  exit 1
fi
systemctl restart opendkim; sleep 1
systemctl restart dovecot; sleep 1
systemctl restart postfix; sleep 2

if command -v nft >/dev/null 2>&1 && nft list table inet servika_fw >/dev/null 2>&1; then
  for p in 25 587 143; do
    nft list chain inet servika_fw input 2>/dev/null | grep -q "dport $p accept" || \
      nft add rule inet servika_fw input tcp dport "$p" accept 2>/dev/null
  done
  log "mail ports 25, 587, and 143 accepted in servika_fw when available"
fi

OK=1
systemctl is-active --quiet postfix || { log "✗ postfix could not be started"; OK=0; }
systemctl is-active --quiet dovecot || { log "✗ dovecot could not be started"; OK=0; }
systemctl is-active --quiet opendkim || { log "✗ opendkim could not be started"; OK=0; }
if [ "$OK" = 1 ]; then
  log "✓ postfix + dovecot + opendkim ACTIVE"
else
  exit 1
fi
echo "════════ ✓ Mail infrastructure ready ════════"

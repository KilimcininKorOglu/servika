#!/usr/bin/env bash
# servika-mail-setup installs or repairs Postfix, Dovecot, OpenDKIM, and Roundcube for virtual mailboxes.
# It reads mail_domains, mailboxes, and mail_aliases through live MySQL maps.
# Roundcube authenticates through Dovecot IMAP and stores only webmail preferences in its own database.
set -uo pipefail

ENV_FILE=/etc/servika/env

load_servika_env() {
  [ -f "$ENV_FILE" ] || return 0
  [ "$(stat -c %u "$ENV_FILE" 2>/dev/null)" = 0 ] || { echo "insecure environment file owner" >&2; exit 1; }
  mode=$(stat -c %a "$ENV_FILE" 2>/dev/null) || { echo "could not read environment file mode" >&2; exit 1; }
  [ $((8#$mode & 077)) -eq 0 ] || { echo "insecure environment file mode" >&2; exit 1; }

  while IFS= read -r line || [ -n "$line" ]; do
    [[ "$line" =~ ^[[:space:]]*(SERVIKA_[A-Za-z0-9_]*)=(.*)$ ]] || continue
    key=${BASH_REMATCH[1]}
    value=${BASH_REMATCH[2]%$'\r'}
    if [[ "$value" == \"*\" && "$value" == *\" ]]; then value=${value:1:${#value}-2}; fi
    if [[ "$value" == \'*\' && "$value" == *\' ]]; then value=${value:1:${#value}-2}; fi
    if [ -z "${!key+x}" ]; then
      printf -v "$key" '%s' "$value"
      export "${key?}"
    fi
  done < "$ENV_FILE"
}

ensure_env_file() {
  mkdir -p "$(dirname "$ENV_FILE")"
  touch "$ENV_FILE"
  chown root:root "$ENV_FILE" 2>/dev/null || true
  chmod 600 "$ENV_FILE"
}

ensure_panel_webmail_location() {
  panel_conf=/etc/nginx/conf.d/_panel.conf
  [ -f "$panel_conf" ] || return 0
  tmp=$(mktemp)
  if ! awk '
    function brace_delta(s, opens, closes) {
      opens = gsub(/\{/, "&", s)
      closes = gsub(/\}/, "&", s)
      return opens - closes
    }
    function emit_webmail() {
      print ""
      print "# Roundcube webmail within the panel port 8443 virtual host."
      print "# Users sign in with their mailbox address and password. SSO is intentionally not used."
      print "location ^~ /webmail/ {"
      print "    alias /opt/roundcube/public_html/;"
      print "    index index.php;"
      print ""
      print "    location ~ ^/webmail/(config|temp|logs|SQL|bin|tests)/ {"
      print "        deny all;"
      print "        return 404;"
      print "    }"
      print ""
      print "    location ~ ^/webmail/static\\.php(/.+)$ {"
      print "        fastcgi_pass unix:/run/php-fpm/roundcube.sock;"
      print "        fastcgi_param SCRIPT_FILENAME /opt/roundcube/public_html/static.php;"
      print "        fastcgi_param PATH_INFO $1;"
      print "        fastcgi_param SCRIPT_NAME /webmail/static.php;"
      print "        include fastcgi_params;"
      print "        fastcgi_read_timeout 60s;"
      print "    }"
      print ""
      print "    location ~ ^/webmail/(.+\\.php)$ {"
      print "        alias /opt/roundcube/public_html/$1;"
      print "        fastcgi_pass unix:/run/php-fpm/roundcube.sock;"
      print "        fastcgi_param SCRIPT_FILENAME /opt/roundcube/public_html/$1;"
      print "        fastcgi_param SCRIPT_NAME /webmail/$1;"
      print "        include fastcgi_params;"
      print "        fastcgi_read_timeout 60s;"
      print "    }"
      print ""
      print "    location ~ ^/webmail/(.+\\.(jpg|jpeg|gif|css|png|js|ico|html|xml|txt|svg|woff2?|map))$ {"
      print "        alias /opt/roundcube/public_html/$1;"
      print "        expires 7d;"
      print "        add_header Cache-Control \"public, immutable\";"
      print "        add_header X-Content-Type-Options \"nosniff\" always;"
      print "        add_header X-Frame-Options \"SAMEORIGIN\" always;"
      print "        add_header Referrer-Policy \"strict-origin-when-cross-origin\" always;"
      print "        add_header Strict-Transport-Security \"max-age=31536000; includeSubDomains\" always;"
      print "    }"
      print "}"
      print ""
    }
    /^[[:space:]]*location[[:space:]]+\^~[[:space:]]+\/webmail\/[[:space:]]*\{/ {
      skip = brace_delta($0)
      if (skip <= 0) skip = 1
      next
    }
    skip > 0 {
      skip += brace_delta($0)
      if (skip <= 0) skip = 0
      next
    }
    { lines[++n] = $0 }
    END {
      last = 0
      for (i = 1; i <= n; i++) {
        if (lines[i] == "}") last = i
      }
      for (i = 1; i <= n; i++) {
        if (i == last) emit_webmail()
        print lines[i]
      }
    }
  ' "$panel_conf" > "$tmp"; then
    rm -f "$tmp"
    log "roundcube nginx location could not be generated"
    return 0
  fi
  if cmp -s "$tmp" "$panel_conf"; then
    rm -f "$tmp"
    return 0
  fi
  cp -a "$panel_conf" "${panel_conf}.servika-webmail-bak" 2>/dev/null || true
  cp "$tmp" "$panel_conf"
  rm -f "$tmp"
  if nginx -t >/tmp/servika-mail-nginx-check.log 2>&1; then
    systemctl reload nginx >/dev/null 2>&1 || true
    log "roundcube nginx location updated"
  else
    cp "${panel_conf}.servika-webmail-bak" "$panel_conf" 2>/dev/null || true
    log "roundcube nginx location was not updated; see /tmp/servika-mail-nginx-check.log"
  fi
}

set_env_value() {
  key=$1
  value=$2
  ensure_env_file
  tmp=$(mktemp)
  if [ -f "$ENV_FILE" ]; then
    grep -v -E "^${key}=" "$ENV_FILE" > "$tmp" 2>/dev/null || true
  fi
  printf '%s=%s\n' "$key" "$value" >> "$tmp"
  install -m 600 -o root -g root "$tmp" "$ENV_FILE"
  rm -f "$tmp"
}

log(){ printf '  %s\n' "$*"; }
fail(){ log "✗ $*"; exit 1; }

[ "$(id -u)" = 0 ] || fail "root is required"
load_servika_env

TMPL="/opt/servika/src/mail-templates"
if [ ! -d "$TMPL" ]; then
  HERE="$(cd "$(dirname "$0")" && pwd)"
  for cand in "$HERE/../assets/mail" "$HERE/assets/mail"; do
    [ -d "$cand" ] && TMPL="$cand" && break
  done
fi
[ -d "$TMPL" ] || fail "mail template directory was not found ($TMPL)"

for dir in postfix dovecot opendkim roundcube; do
  [ -d "$TMPL/$dir" ] || fail "mail template directory is incomplete: $TMPL/$dir"
done

echo "════ Postfix + Dovecot + OpenDKIM packages ════"
dnf install -y postfix postfix-mysql dovecot dovecot-mysql opendkim >/tmp/servika-mail-setup.log 2>&1 \
  && log "postfix + postfix-mysql + dovecot + dovecot-mysql + opendkim installed" || fail "mail packages could not be installed"

echo "════ mailro database password ════"
DBPASS=${SERVIKA_MAIL_DB_PASS:-}
if [ -n "$DBPASS" ] && ! [[ "$DBPASS" =~ ^[A-Za-z0-9._%+=:@-]{16,128}$ ]]; then
  fail "SERVIKA_MAIL_DB_PASS contains unsupported characters or has an invalid length"
fi
if [ -z "$DBPASS" ]; then
  DBPASS=$(openssl rand -hex 24)
  set_env_value SERVIKA_MAIL_DB_PASS "$DBPASS"
  export SERVIKA_MAIL_DB_PASS="$DBPASS"
  log "mailro password generated and added to the environment file"
fi

echo "════ mailro database user ════"
mysql -u root <<SQL 2>/dev/null || fail "mailro user or grants could not be created"
CREATE USER IF NOT EXISTS 'mailro'@'127.0.0.1' IDENTIFIED BY '${DBPASS}';
ALTER USER 'mailro'@'127.0.0.1' IDENTIFIED BY '${DBPASS}';
GRANT SELECT ON panel.mail_domains TO 'mailro'@'127.0.0.1';
GRANT SELECT ON panel.mailboxes TO 'mailro'@'127.0.0.1';
GRANT SELECT ON panel.mail_aliases TO 'mailro'@'127.0.0.1';
FLUSH PRIVILEGES;
SQL
log "mailro user has SELECT access to mail tables"

echo "════ Postfix virtual mailbox maps ════"
for f in mysql-virtual-domains.cf mysql-virtual-mailboxes.cf mysql-virtual-uid.cf mysql-virtual-gid.cf mysql-virtual-aliases.cf; do
  sed "s/__SERVIKA_MAIL_DB_PASS__/${DBPASS}/" "$TMPL/postfix/${f}.tmpl" > "/etc/postfix/${f}"
  chown root:postfix "/etc/postfix/${f}"
  chmod 640 "/etc/postfix/${f}"
done
log "5 mysql-virtual-*.cf files written"

echo "════ Postfix main.cf and master.cf ════"
if ! grep -q 'servika-mail' /etc/postfix/main.cf; then
  cat "$TMPL/postfix/main.cf.append" >> /etc/postfix/main.cf
  log "servika-mail block added to main.cf"
fi
postconf -e 'inet_interfaces = all' 2>/dev/null || {
  grep -qE '^inet_interfaces[[:space:]]*=' /etc/postfix/main.cf 2>/dev/null \
    && sed -i 's/^inet_interfaces[[:space:]]*=.*/inet_interfaces = all/' /etc/postfix/main.cf \
    || printf '\ninet_interfaces = all\n' >> /etc/postfix/main.cf
}
log "postfix listens on all interfaces"
if ! grep -qE '^submission[[:space:]]+inet' /etc/postfix/master.cf; then
  cat "$TMPL/postfix/master.cf.append" >> /etc/postfix/master.cf
  log "submission service added to master.cf"
fi

echo "════ Dovecot SQL auth and drop-in config ════"
sed "s/__SERVIKA_MAIL_DB_PASS__/${DBPASS}/" "$TMPL/dovecot/dovecot-sql.conf.ext.tmpl" > /etc/dovecot/dovecot-sql.conf.ext
chown root:dovecot /etc/dovecot/dovecot-sql.conf.ext
chmod 640 /etc/dovecot/dovecot-sql.conf.ext
cp "$TMPL/dovecot/10-servika-mail.conf.tmpl" /etc/dovecot/conf.d/10-servika-mail.conf
log "dovecot-sql.conf.ext and 10-servika-mail.conf installed"

echo "════ OpenDKIM ════"
mkdir -p /etc/opendkim/keys
touch /etc/opendkim/KeyTable /etc/opendkim/SigningTable
if [ ! -f /etc/opendkim/TrustedHosts ]; then
  printf '127.0.0.1\nlocalhost\n' > /etc/opendkim/TrustedHosts
fi
chown -R opendkim:opendkim /etc/opendkim
cp "$TMPL/opendkim/opendkim.conf.tmpl" /etc/opendkim.conf
chown root:opendkim /etc/opendkim.conf
chmod 640 /etc/opendkim.conf
log "/etc/opendkim.conf and table files installed"

echo "════ Maildir roots for active domains ════"
mysql -u root -N -e "SELECT system_user FROM panel.mail_domains WHERE status='active'" 2>/dev/null | while read -r system_user; do
  [ -n "$system_user" ] || continue
  getent passwd "$system_user" >/dev/null || continue
  mkdir -p "/home/${system_user}/mail"
  chown "${system_user}:${system_user}" "/home/${system_user}/mail" 2>/dev/null
  chmod 750 "/home/${system_user}/mail" 2>/dev/null
done

echo "════ SELinux ════"
setsebool -P httpd_can_network_connect_db 1 2>/dev/null && log "httpd_can_network_connect_db=1"
if command -v getenforce >/dev/null 2>&1 && [ "$(getenforce)" != "Disabled" ]; then
  log "SELinux is enforcing; run servika-repair --only mail if mail service AVC denials appear"
fi

echo "════ postfix + dovecot + opendkim enable and restart ════"
systemctl enable postfix dovecot opendkim >/dev/null 2>&1
if ! postfix check >/tmp/servika-mail-postfix-check.log 2>&1; then
  log "✗ postfix check failed; see /tmp/servika-mail-postfix-check.log"
  exit 1
fi
systemctl restart opendkim; sleep 1
systemctl restart dovecot; sleep 1
systemctl restart postfix; sleep 2

if command -v nft >/dev/null 2>&1 && nft list table inet servika_fw >/dev/null 2>&1; then
  for p in 25 587 143; do
    nft list chain inet servika_fw input 2>/dev/null | grep -q "dport $p accept" || \
      nft add rule inet servika_fw input tcp dport "$p" accept 2>/dev/null
  done
  log "mail ports 25, 587, and 143 accepted in servika_fw when available"
fi

OK=1
systemctl is-active --quiet postfix || { log "✗ postfix could not be started"; OK=0; }
systemctl is-active --quiet dovecot || { log "✗ dovecot could not be started"; OK=0; }
systemctl is-active --quiet opendkim || { log "✗ opendkim could not be started"; OK=0; }
if [ "$OK" = 1 ]; then
  log "✓ postfix + dovecot + opendkim ACTIVE"
else
  exit 1
fi

echo "════ Roundcube webmail (/webmail/) ════"
dnf install -y php-intl >/dev/null 2>&1 \
  && log "php-intl installed for Roundcube" || log "php-intl could not be installed; webmail login may fail"
RCVER=1.7.2
mkdir -p /opt/roundcube
if [ ! -f /opt/roundcube/index.php ]; then
  RCTMP=$(mktemp -d)
  if curl -fsSL -o "$RCTMP/roundcube.tar.gz" \
       "https://github.com/roundcube/roundcubemail/releases/download/${RCVER}/roundcubemail-${RCVER}-complete.tar.gz" \
     && tar xzf "$RCTMP/roundcube.tar.gz" -C /opt/roundcube --strip-components=1; then
    log "roundcube ${RCVER} downloaded and extracted"
  else
    log "✗ roundcube could not be downloaded; webmail skipped without affecting mail transport"
  fi
  rm -rf "$RCTMP"
fi

if [ -f /opt/roundcube/index.php ]; then
  RCDBPASS=${SERVIKA_ROUNDCUBE_DB_PASS:-}
  if [ -n "$RCDBPASS" ] && ! [[ "$RCDBPASS" =~ ^[A-Za-z0-9._%+=-]{16,128}$ ]]; then
    fail "SERVIKA_ROUNDCUBE_DB_PASS contains unsupported characters or has an invalid length"
  fi
  if [ -z "$RCDBPASS" ]; then
    RCDBPASS=$(openssl rand -hex 24)
    set_env_value SERVIKA_ROUNDCUBE_DB_PASS "$RCDBPASS"
    export SERVIKA_ROUNDCUBE_DB_PASS="$RCDBPASS"
    log "roundcube database password generated and added to the environment file"
  fi

  RCDESKEY=${SERVIKA_ROUNDCUBE_DES_KEY:-}
  if [ -n "$RCDESKEY" ] && ! [[ "$RCDESKEY" =~ ^[A-Za-z0-9._%+=:@-]{16,128}$ ]]; then
    fail "SERVIKA_ROUNDCUBE_DES_KEY contains unsupported characters or has an invalid length"
  fi
  if [ -z "$RCDESKEY" ]; then
    RCDESKEY=$(openssl rand -hex 16)
    set_env_value SERVIKA_ROUNDCUBE_DES_KEY "$RCDESKEY"
    export SERVIKA_ROUNDCUBE_DES_KEY="$RCDESKEY"
    log "roundcube encryption key generated and added to the environment file"
  fi

  mysql -u root <<SQL 2>/dev/null || fail "roundcube database or grants could not be created"
CREATE DATABASE IF NOT EXISTS roundcube CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
CREATE USER IF NOT EXISTS 'roundcube'@'localhost' IDENTIFIED BY '${RCDBPASS}';
ALTER USER 'roundcube'@'localhost' IDENTIFIED BY '${RCDBPASS}';
GRANT ALL PRIVILEGES ON roundcube.* TO 'roundcube'@'localhost';
FLUSH PRIVILEGES;
SQL

  RCTBL=$(mysql -u root -N -e "SELECT COUNT(*) FROM information_schema.tables WHERE table_schema='roundcube'" 2>/dev/null)
  if [ "${RCTBL:-0}" = "0" ] && [ -f /opt/roundcube/SQL/mysql.initial.sql ]; then
    mysql -u root roundcube < /opt/roundcube/SQL/mysql.initial.sql 2>/dev/null && log "roundcube database schema applied"
  fi

  mkdir -p /opt/roundcube/config
  sed -e "s/__SERVIKA_ROUNDCUBE_DB_PASS__/${RCDBPASS}/" -e "s/__SERVIKA_ROUNDCUBE_DES_KEY__/${RCDESKEY}/" \
    "$TMPL/roundcube/config.inc.php.tmpl" > /opt/roundcube/config/config.inc.php
  chown root:apache /opt/roundcube/config/config.inc.php
  chmod 640 /opt/roundcube/config/config.inc.php

  mkdir -p /var/lib/roundcube/sessions /var/lib/roundcube/temp
  chown -R apache:apache /opt/roundcube /var/lib/roundcube
  restorecon -R /opt/roundcube /var/lib/roundcube >/dev/null 2>&1
  ensure_panel_webmail_location
  systemctl reload php-fpm >/dev/null 2>&1 || systemctl restart php-fpm >/dev/null 2>&1
  log "✓ roundcube configured at /webmail/"
fi

echo "════════ ✓ Mail infrastructure ready ════════"

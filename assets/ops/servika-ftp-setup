#!/usr/bin/env bash
# servika-ftp-setup installs or repairs Pure-FTPd with a MySQL backend.
# It provides chrooted virtual-user FTP with passive mode and TLS by reading ftp_accounts.
# The operation is idempotent and safe to run repeatedly.
set -uo pipefail

c_g="\033[32m"; c_r="\033[31m"; c_y="\033[33m"; c_0="\033[0m"
[ -t 1 ] || { c_g=; c_r=; c_y=; c_0=; }
ok(){ echo -e "  ${c_g}✓${c_0} $*"; }
warn(){ echo -e "  ${c_y}!${c_0} $*"; }
die(){ echo -e "  ${c_r}✗${c_0} $*"; exit 1; }

[ "$(id -u)" = 0 ] || die "root is required"

ENVF=/etc/servika/env
SERVIKA_DB_PASS=$(grep -oP '^SERVIKA_DB_PASS=\K.*' "$ENVF" 2>/dev/null || true)
# Fall back to extracting the password from the DSN.
[ -z "${SERVIKA_DB_PASS:-}" ] && SERVIKA_DB_PASS=$(grep -oP 'panel:\K[^@]*' "$ENVF" 2>/dev/null | head -1 || true)

echo "══ Pure-FTPd installation (MySQL backend) ══"

# 1) Package installation
if ! rpm -q pure-ftpd >/dev/null 2>&1; then
  dnf install -y pure-ftpd >/dev/null 2>&1 && ok "pure-ftpd installed" || die "pure-ftpd could not be installed (EPEL required)"
else ok "pure-ftpd is already installed"; fi

# 2) Read-only MySQL user with SELECT access to ftp_accounts
PFPW_FILE=/etc/pure-ftpd/.pfsql_pass
if [ -s "$PFPW_FILE" ]; then PFPW=$(cat "$PFPW_FILE"); else PFPW=$(openssl rand -hex 20); fi
# The ftp_accounts table is created by a migration, so the installer invokes this after
# the panel starts. If the table is still absent, grant access to panel.* as a fallback.
mysql -e "CREATE USER IF NOT EXISTS 'pureftpd'@'localhost' IDENTIFIED BY '$PFPW';
          ALTER USER 'pureftpd'@'localhost' IDENTIFIED BY '$PFPW';" 2>/dev/null || warn "pureftpd user"
if ! mysql -e "GRANT SELECT ON panel.ftp_accounts TO 'pureftpd'@'localhost'; FLUSH PRIVILEGES;" 2>/dev/null; then
  mysql -e "GRANT SELECT ON panel.* TO 'pureftpd'@'localhost'; FLUSH PRIVILEGES;" 2>/dev/null && warn "ftp_accounts table is absent; access was granted to panel.*"
fi
ok "MySQL user 'pureftpd' (SELECT ftp_accounts)"
umask 077; echo "$PFPW" > "$PFPW_FILE"; chmod 600 "$PFPW_FILE"

# 3) Pure-FTPd MySQL configuration
SOCK=$(mysql -N -e "SHOW VARIABLES LIKE 'socket';" 2>/dev/null | awk '{print $2}'); [ -z "$SOCK" ] && SOCK=/var/lib/mysql/mysql.sock
cat > /etc/pure-ftpd/pureftpd-mysql.conf <<EOF
MYSQLSocket     $SOCK
MYSQLServer     localhost
MYSQLPort       3306
MYSQLUser       pureftpd
MYSQLPassword   $PFPW
MYSQLDatabase   panel
MYSQLCrypt      cleartext
MYSQLGetPW      SELECT password_md5 FROM ftp_accounts WHERE username="\L" AND status='active'
MYSQLGetUID     SELECT uid_n FROM ftp_accounts WHERE username="\L" AND status='active'
MYSQLGetGID     SELECT gid_n FROM ftp_accounts WHERE username="\L" AND status='active'
MYSQLGetDir     SELECT home_dir FROM ftp_accounts WHERE username="\L" AND status='active'
EOF
chmod 640 /etc/pure-ftpd/pureftpd-mysql.conf; chown root:root /etc/pure-ftpd/pureftpd-mysql.conf
ok "pureftpd-mysql.conf (ftp_accounts queries)"

# 4) Self-signed TLS certificate for explicit FTPS
mkdir -p /etc/ssl/private
if [ ! -s /etc/pki/pure-ftpd/pure-ftpd.pem ]; then
  mkdir -p /etc/pki/pure-ftpd
  openssl req -x509 -nodes -newkey rsa:2048 -days 3650 \
    -keyout /etc/pki/pure-ftpd/pure-ftpd.pem -out /etc/pki/pure-ftpd/pure-ftpd.pem \
    -subj "/CN=$(hostname -f 2>/dev/null || hostname)" >/dev/null 2>&1
  chmod 600 /etc/pki/pure-ftpd/pure-ftpd.pem
  ok "self-signed TLS certificate created"
else ok "TLS certificate already exists"; fi

# 5) pure-ftpd.conf with MySQL authentication, chroot, passive mode, and optional TLS
CONF=/etc/pure-ftpd/pure-ftpd.conf
set_directive(){ # $1=directive $2=value
  # Remove every active or commented directive before writing one canonical value.
  sed -i -E "/^[# ]*$1[[:space:]]/d" "$CONF"
  echo "$1                  $2" >> "$CONF"
}
set_directive MySQLConfigFile /etc/pure-ftpd/pureftpd-mysql.conf
set_directive ChrootEveryone   yes
set_directive NoAnonymous      yes
set_directive PassivePortRange "30000 30100"
set_directive CreateHomeDir    yes
set_directive TLS              1
set_directive TLSCipherSuite   HIGH
set_directive CertFile         /etc/pki/pure-ftpd/pure-ftpd.pem
set_directive DontResolve      yes
set_directive MaxClientsNumber 50
set_directive MaxClientsPerIP  8
set_directive UnixAuthentication no
set_directive PAMAuthentication  no
ok "pure-ftpd.conf configured (MySQL auth, chroot, passive 30000-30100, TLS)"

# 6) SELinux access to home directories, MySQL, and passive FTP
if command -v setsebool >/dev/null 2>&1; then
  setsebool -P ftpd_full_access 1 2>/dev/null
  setsebool -P ftpd_connect_db 1 2>/dev/null
  setsebool -P ftpd_use_passive_mode 1 2>/dev/null
  ok "SELinux ftpd booleans"
fi

# 7) Firewall rules for port 21 and the passive range when servika_fw exists
if command -v nft >/dev/null 2>&1 && nft list table inet servika_fw >/dev/null 2>&1; then
  for p in 21 "30000-30100"; do
    nft list chain inet servika_fw input 2>/dev/null | grep -q "dport $p accept" || \
      nft add rule inet servika_fw input tcp dport $p accept 2>/dev/null
  done
  ok "nft: port 21 + passive range 30000-30100 open"
else warn "nft servika_fw is absent; firewall ACCEPT is assumed (21 + 30000-30100 must be open)"; fi

# 8) Service startup
systemctl enable --now pure-ftpd >/dev/null 2>&1
systemctl restart pure-ftpd >/dev/null 2>&1; sleep 1
if systemctl is-active --quiet pure-ftpd; then ok "pure-ftpd ACTIVE (port 21)"; else
  journalctl -u pure-ftpd --no-pager -n 15; die "pure-ftpd did not start"; fi

echo -e "${c_g}══ FTP installation complete; panel ftp_accounts virtual users are active ══${c_0}"

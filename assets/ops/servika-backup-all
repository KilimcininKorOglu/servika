#!/bin/bash
# servika-backup-all performs daily scheduled backups through cron
ENV=/etc/servika/env
[ -f "$ENV" ] || exit 0
DB_PASS=$(grep -oP 'SERVIKA_DB_DSN=panel:\K[^@]+' "$ENV" | head -1)
[ -z "$DB_PASS" ] && exit 0

find /var/backups/servika -type f -name '*.tar.gz' -mtime +14 -delete 2>/dev/null

mysql -h 127.0.0.1 -u panel -p"$DB_PASS" panel -N -e \
  "SELECT id, domain_name, system_user FROM domains WHERE is_demo=0" 2>/dev/null | \
while IFS=$'\t' read -r id domain_name system_user; do
  [ -z "$system_user" ] && continue
  STAMP=$(date -u +%Y%m%d-%H%M%S)
  DIR="/var/backups/servika/$system_user"
  mkdir -p "$DIR"; chmod 700 "$DIR"
  FILE="${system_user}-${STAMP}-scheduled.tar.gz"
  DB_NAME="${system_user}_main"
  mysqldump --single-transaction "$DB_NAME" > "$DIR/dump.sql" 2>/dev/null || echo "-- skipped" > "$DIR/dump.sql"
  tar czf "$DIR/$FILE" -C /home "$system_user" -C "$DIR" dump.sql 2>/dev/null
  rm -f "$DIR/dump.sql"
  if [ -f "$DIR/$FILE" ]; then
    SIZE=$(stat -c %s "$DIR/$FILE")
    mysql -h 127.0.0.1 -u panel -p"$DB_PASS" panel -e \
      "INSERT INTO backups(domain_id, type, file, size_b, notes) VALUES($id, 'scheduled', '$FILE', $SIZE, 'daily cron')" 2>/dev/null
    logger -t servika-backup "OK $domain_name -> $FILE ($SIZE B)"
  fi
done

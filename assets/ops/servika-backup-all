#!/usr/bin/env bash
# servika-backup-all performs daily scheduled backups through cron.
set -uo pipefail

ENV_FILE=/etc/servika/env

load_servika_env() {
  [ -f "$ENV_FILE" ] || exit 0
  [ "$(stat -c %u "$ENV_FILE" 2>/dev/null)" = 0 ] || { logger -t servika-backup "insecure environment file owner"; exit 1; }
  mode=$(stat -c %a "$ENV_FILE" 2>/dev/null) || { logger -t servika-backup "could not read environment file mode"; exit 1; }
  [ $((8#$mode & 077)) -eq 0 ] || { logger -t servika-backup "insecure environment file mode"; exit 1; }

  while IFS= read -r line || [ -n "$line" ]; do
    [[ "$line" =~ ^[[:space:]]*(SERVIKA_[A-Za-z0-9_]*)=(.*)$ ]] || continue
    key=${BASH_REMATCH[1]}
    value=${BASH_REMATCH[2]%$'\r'}
    if [[ "$value" == \"*\" && "$value" == *\" ]]; then value=${value:1:${#value}-2}; fi
    if [[ "$value" == \'*\' && "$value" == *\' ]]; then value=${value:1:${#value}-2}; fi
    if [ -z "${!key+x}" ]; then
      printf -v "$key" '%s' "$value"
      export "${key?}"
    fi
  done < "$ENV_FILE"
}

panel_db_password() {
  if [ -n "${SERVIKA_DB_PASS:-}" ]; then
    printf '%s' "$SERVIKA_DB_PASS"
    return 0
  fi
  dsn=${SERVIKA_DB_DSN:-}
  [ -n "$dsn" ] || return 1
  dsn=${dsn#panel:}
  printf '%s' "${dsn%%@*}"
}

load_servika_env
BACKUP_ROOT="${SERVIKA_BACKUP_ROOT:-/var/backups/servika}"
case "$BACKUP_ROOT" in
  /*) ;;
  *) logger -t servika-backup "SERVIKA_BACKUP_ROOT must be an absolute path: $BACKUP_ROOT"; exit 1 ;;
esac
DB_PASS=$(panel_db_password) || exit 0
[ -z "$DB_PASS" ] && exit 0

find "$BACKUP_ROOT" -type f -name '*.tar.gz' -mtime +14 -delete 2>/dev/null

mysql -h 127.0.0.1 -u panel -p"$DB_PASS" panel --batch --raw --skip-column-names -e \
  "SELECT id, domain_name, system_user FROM domains WHERE is_demo=0" 2>/dev/null | \
while IFS=$'\t' read -r id domain_name system_user; do
  [[ "$id" =~ ^[0-9]+$ ]] || continue
  [[ "$system_user" =~ ^[a-z0-9_]{1,32}$ ]] || continue
  STAMP=$(date -u +%Y%m%d-%H%M%S)
  DIR="$BACKUP_ROOT/$system_user"
  mkdir -p "$DIR"; chmod 700 "$DIR"
  FILE="${system_user}-${STAMP}-scheduled.tar.gz"
  DB_NAME="${system_user}_main"
  # Dump into a private temp dir. Fail closed: if mysqldump fails, skip this
  # domain instead of archiving a placeholder that restore cannot use.
  DUMP_DIR=$(mktemp -d) || continue
  if ! mysqldump --single-transaction "$DB_NAME" > "$DUMP_DIR/dump.sql" 2>/dev/null; then
    logger -t servika-backup "SKIP $domain_name: mysqldump failed for $DB_NAME"
    rm -rf "$DUMP_DIR"
    continue
  fi
  tar czf "$DIR/$FILE" -C /home "$system_user" -C "$DUMP_DIR" dump.sql 2>/dev/null
  rm -rf "$DUMP_DIR"
  if [ -f "$DIR/$FILE" ]; then
    SIZE=$(stat -c %s "$DIR/$FILE")
    [[ "$SIZE" =~ ^[0-9]+$ ]] || continue
    ESC_FILE=${FILE//\'/\'\'}
    mysql -h 127.0.0.1 -u panel -p"$DB_PASS" panel 2>/dev/null <<SQL
INSERT INTO backups(domain_id, type, file, size_b, notes) VALUES($id, 'scheduled', '$ESC_FILE', $SIZE, 'daily cron');
SQL
    logger -t servika-backup "OK $domain_name -> $FILE ($SIZE B)"
  fi
done

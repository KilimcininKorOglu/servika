# Servika virtual mailboxes. This file is installed as a single Dovecot drop-in.
protocols = imap lmtp

mail_location = maildir:~/

passdb {
  driver = sql
  args = /etc/dovecot/dovecot-sql.conf.ext
}
userdb {
  driver = sql
  args = /etc/dovecot/dovecot-sql.conf.ext
}

service auth {
  unix_listener /var/spool/postfix/private/auth {
    mode = 0660
    user = postfix
    group = postfix
  }
}

service lmtp {
  unix_listener /var/spool/postfix/private/dovecot-lmtp {
    mode = 0660
    user = postfix
    group = postfix
  }
}

ssl_cert = </etc/ssl/servika/panel.crt
ssl_key = </etc/ssl/servika/panel.key
